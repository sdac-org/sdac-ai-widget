# =============================================================================
# SDAC AI Widget - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# For Docker deployment, these variables can also be passed via docker-compose.yml
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the server will listen on (default: 5000)
PORT=5000

# -----------------------------------------------------------------------------
# Mastra Agent Connection (Server-side)
# -----------------------------------------------------------------------------
# URL of the Mastra server
MASTRA_BASE_URL=http://localhost:4111

# Agent ID for SDAC operations (runtime, served to client via GET /api/config)
MASTRA_AGENT_ID=sdac-coordinator-release

# -----------------------------------------------------------------------------
# Ingestion Server Connection (Server-side)
# -----------------------------------------------------------------------------
# URL of the Ingestion Server for file uploads
INGESTION_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Client Configuration (Build-time - VITE_* prefix)
# -----------------------------------------------------------------------------
# These variables are embedded in the client bundle at build time.
# For Docker, pass these as build args.

# Report ID - If set, Mastra fetches report data from DB using this ID
# Leave empty to require file upload
VITE_REPORT_ID=

# Example: VITE_REPORT_ID=8201EDC2-2EDE-4CA1-AF44-D0F5AA185CDB

# -----------------------------------------------------------------------------
# Demo User Configuration (for local testing without auth)
# -----------------------------------------------------------------------------
VITE_DEMO_USER_ID=demo-user
VITE_DEMO_USER_NAME=Demo User
VITE_DEMO_USER_EMAIL=demo@example.com
VITE_DEMO_USER_ROLE=District Admin
VITE_DEMO_DISTRICT=Demo District

# District ID (used by session context and host page context)
VITE_DEMO_DISTRICT_ID=

# -----------------------------------------------------------------------------
# Docker-specific notes:
# -----------------------------------------------------------------------------
# When running in Docker:
# - Server-side vars (MASTRA_BASE_URL, INGESTION_API_URL) should point to
#   host.docker.internal:<port> to reach services on the host machine,
#   or use container names if services are in the same Docker network.
#
# Example for Docker:
#   MASTRA_BASE_URL=http://host.docker.internal:4111
#   INGESTION_API_URL=http://host.docker.internal:8000
