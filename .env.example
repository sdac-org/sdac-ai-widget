# Mastra agent connection
MASTRA_BASE_URL=http://localhost:4111
MASTRA_AGENT_ID=SDAC_coordinator_release

# Optional client override (Vite only exposes VITE_* vars)
VITE_MASTRA_AGENT_ID=

# Report Configuration
# Set VITE_REPORT_ID to fetch real data from Mastra tools
# Leave empty to use mock data
VITE_REPORT_ID=
# Example: VITE_REPORT_ID=8201EDC2-2EDE-4CA1-AF44-D0F5AA185CDB

# Mastra base URL for client-side tool calls (optional, defaults to http://localhost:4111)
VITE_MASTRA_BASE_URL=http://localhost:4111
